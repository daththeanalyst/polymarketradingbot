# Polymarket Bot Configuration
# Copy this file to .env and fill in your credentials
# NEVER share your .env file or commit it to git

# Your Polymarket wallet private key
# Export from: https://reveal.magic.link/polymarket
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Your Polymarket proxy wallet address (find in Polymarket → Settings → your wallet address)
# Only needed for email/Google sign-up (not MetaMask)
PROXY_WALLET=0xYOUR_PROXY_WALLET_HERE

# Wallet type: "email" if you signed up with email/Google, "metamask" if you used MetaMask
WALLET_TYPE=email

# API credentials (generated automatically by the bot on first run)
# You can leave these blank — the bot will fill them in
API_KEY=
API_SECRET=
API_PASSPHRASE=
